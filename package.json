{
	"name": "@c9up/pulsar",
	"version": "0.1.0",
	"description": "Pulsar — Rust-powered event bus for the Ream framework (standalone)",
	"license": "MIT",
	"type": "module",
	"main": "index.js",
	"types": "index.d.ts",
	"files": [
		"LICENSE",
		"README.md",
		"dist",
		"index.*.node",
		"index.d.ts",
		"index.js",
		"src"
	],
	"exports": {
		".": {
			"import": "./index.js",
			"types": "./index.d.ts"
		},
		"./events": {
			"types": "./dist/Emitter.d.ts",
			"development": "./src/Emitter.ts",
			"import": "./dist/Emitter.js"
		},
		"./provider": {
			"types": "./dist/PulsarProvider.d.ts",
			"development": "./src/PulsarProvider.ts",
			"import": "./dist/PulsarProvider.js"
		},
		"./services/main": {
			"types": "./dist/services/main.d.ts",
			"development": "./src/services/main.ts",
			"import": "./dist/services/main.js"
		},
		"./helix": {
			"types": "./dist/helix/helpers.d.ts",
			"development": "./src/helix/helpers.ts",
			"import": "./dist/helix/helpers.js"
		},
		"./testing": {
			"types": "./dist/testing/FakeBus.d.ts",
			"development": "./src/testing/FakeBus.ts",
			"import": "./dist/testing/FakeBus.js"
		},
		"./config": {
			"types": "./dist/config.d.ts",
			"development": "./src/config.ts",
			"import": "./dist/config.js"
		},
		"./configure": {
			"types": "./dist/configure.d.ts",
			"development": "./src/configure.ts",
			"import": "./dist/configure.js"
		}
	},
	"peerDependencies": {
		"@c9up/ream": "workspace:*"
	},
	"scripts": {
		"build:rust": "cargo build --release -p pulsar-bus-napi",
		"build:napi": "pnpm build:rust && node scripts/copy-napi.mjs",
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest run",
		"test:rust": "cargo test -p pulsar-bus",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/",
		"test:coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
